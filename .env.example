# Logging level (e.g., info, debug, trace)
RUST_LOG=info

# HTTP host to bind to
HOST=0.0.0.0

# HTTP server port
PORT=8080

# Type of signer to use (required)
SIGNER_TYPE=private-key

# Private key in hex for EVM networks (required)
EVM_PRIVATE_KEY=0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# Private key in hex for Solana networks (required)
SOLANA_PRIVATE_KEY=0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# Ethereum RPC endpoint for Base Sepolia testnet
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org

# Ethereum RPC endpoint for Base mainnet
RPC_URL_BASE=https://mainnet.base.org

# Ethereum RPC endpoint for Avalanche Fuji testnet
RPC_URL_AVALANCHE_FUJI=https://api.avax-test.network/ext/bc/C/rpc

# Ethereum RPC endpoint for Avalanche C-Chain mainnet
RPC_URL_AVALANCHE=https://api.avax.network/ext/bc/C/rpc

# RPC endpoint for Solana mainnet
RPC_URL_SOLANA=https://api.mainnet-beta.solana.com

# RPC endpoint for Solana devnet
RPC_URL_SOLANA_DEVNET=https://api.devnet.solana.com

# RPC endpoint for Polygon mainnet
RPC_URL_POLYGON=https://polygon-rpc.com

# RPC endpoint for Polygon Amoy testnet
RPC_URL_POLYGON_AMOY=https://rpc-amoy.polygon.technology

# RPC endpoint for Sei mainnet
RPC_URL_SEI=https://sei-rpc.example.com

# RPC endpoint for Sei testnet
RPC_URL_SEI_TESTNET=https://sei-testnet-rpc.example.com
